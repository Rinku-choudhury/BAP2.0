In backend code

app.get('/api/get-state', (req, res) => {

  const { value
  } = req.query;

  return res.status(200).json({
    status: 200,
    message: 'success',
    data: {
      name: "Pankaj",
      addressLine2: "Line 2",
      state: [
        { id: '1', name: 'MP'
        }
      ],
      city: [
        { id: '1', name: 'Bhopal'
        }
      ]
    }
  });
});


